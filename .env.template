# LinkedIn Enricher Environment Configuration
# Using: Realtime LinkedIn Bulk Data API (https://rapidapi.com/apibuilderz/api/realtime-linkedin-bulk-data)

# ============================================
# RapidAPI Configuration (REQUIRED)
# ============================================
RAPIDAPI_KEY=your_api_key_here
RAPIDAPI_HOST=realtime-linkedin-bulk-data.p.rapidapi.com

# ============================================
# Slack Integration (OPTIONAL)
# ============================================
SLACK_WEBHOOK_URL=

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# ============================================
# Application Settings
# ============================================
MAX_WORKERS=5
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=1

# ============================================
# Setup Instructions:
# ============================================
#
# 1. Get your API Key:
#    - Go to: https://rapidapi.com/apibuilderz/api/realtime-linkedin-bulk-data
#    - Click "Subscribe to Test"
#    - Copy your "X-RapidAPI-Key"
#    - Replace "your_api_key_here" above
#
# 2. API Host is already set: realtime-linkedin-bulk-data.p.rapidapi.com
#
# 3. (Optional) Slack Webhook for notifications:
#    - Go to: https://api.slack.com/messaging/webhooks
#    - Create webhook for your Slack workspace
#    - Paste URL as SLACK_WEBHOOK_URL
#
